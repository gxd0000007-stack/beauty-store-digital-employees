      "tables": ["产品耗材成本表", "出入库台账"],
      "dashboards": ["库存总览", "产品耗材成本", "出入库管理"]
    },
    {
      "name": "06 营销管理",
      "tables": ["活动购卡登记表", "营销活动预算表"],
      "dashboards": ["营销总览", "活动购卡分析", "营销预算分析"]
