      "dashboards": ["顾客总览", "预约看板", "消费分析", "会员等级", "会员月度规划", "会员生日提醒看板"]
    },
    {
      "name": "04 员工管理",
      "tables": ["员工业绩表", "各岗位绩效考核表", "考勤表", "员工日常扣分加分详情表", "员工每日小记"],
      "dashboards": ["员工总览", "员工业绩", "薪酬分析", "绩效考核", "考勤管理", "员工每日小记看板"]
